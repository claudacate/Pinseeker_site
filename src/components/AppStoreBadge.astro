---
/**
 * "Download on the App Store" call-to-action.
 * Uses Apple's OFFICIAL, unmodified badge artwork (localized SVG in
 * public/badges/, sourced from Apple's Marketing Tools), per Apple's
 * App Store Marketing Guidelines — never a custom recreation.
 * Always a real clickable link to `site.appStoreUrl` (the download location).
 * That URL is a PLACEHOLDER until the app is published — see src/config.ts.
 */
import { site } from "../config";
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props {
  /** Show the "N free putts every day" line under the badge. */
  showTrial?: boolean;
  lang?: Locale;
}
const { showTrial = true, lang = defaultLocale } = Astro.props;
const c = getContent(lang).common;
const label = `${c.downloadSmall} ${c.downloadBig}`;
---

<div class="cta">
  <a
    class="appbadge"
    href={site.appStoreUrl}
    target="_blank"
    rel="noopener"
    aria-label={label}
  >
    <img src={`/badges/appstore-${lang}.svg`} alt={label} height="48" />
  </a>
  {showTrial && <p class="cta__note">{c.freeNote}</p>}
</div>

<style>
  .cta { display: inline-flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }

  /* Apple's badge artwork must stay unmodified — only a position nudge on
     hover (the badge itself is not recolored, scaled, or restyled).
     Padding gives the required minimum clear space around the badge. */
  .appbadge {
    display: inline-block;
    padding: 6px;
    transition: transform 0.15s ease;
  }
  .appbadge:hover { transform: translateY(-1px); }
  .appbadge img { display: block; height: 48px; width: auto; }

  .cta__note { font-size: 0.85rem; color: var(--ink-faint); }
</style>
