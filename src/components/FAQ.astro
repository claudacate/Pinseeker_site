---
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).faq;
---

<section class="section faq" id="faq">
  <div class="container container--narrow">
    <header class="faq__head">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 set:html={t.h2}></h2>
    </header>

    <div class="faq__list">
      {t.items.map((f) => (
        <details class="faq__item">
          <summary>
            <span>{f.q}</span>
            <svg class="faq__chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__head { margin-bottom: clamp(2rem, 5vw, 3rem); }
  .faq__head h2 { margin-top: 0.75rem; }

  .faq__list { display: flex; flex-direction: column; }
  .faq__item { border-bottom: 1px solid var(--line); }
  .faq__item summary {
    list-style: none; cursor: pointer; padding: 1.25rem 0;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    font-family: var(--font-serif); font-size: 1.15rem; font-weight: 500; color: var(--ink);
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary:hover { color: var(--accent); }
  .faq__chev { width: 22px; height: 22px; flex-shrink: 0; color: var(--ink-faint); transition: transform 0.2s ease; }
  .faq__item[open] .faq__chev { transform: rotate(180deg); color: var(--accent); }
  .faq__item p { color: var(--ink-soft); font-size: 1rem; padding: 0 0 1.4rem; max-width: 62ch; }
</style>
