---
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).features;
const iconKeys = ["tempo", "speed", "distance", "direction"];
const features = t.items.map((f, i) => ({ ...f, icon: iconKeys[i] }));

// Stroke-based inline icons, inherit currentColor.
const icons: Record<string, string> = {
  tempo: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 20h14L12 3z"/><path d="M12 14l4-5"/><circle cx="12" cy="16" r="1.2" fill="currentColor" stroke="none"/></svg>`,
  speed: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14a8 8 0 0 1 8-8"/><path d="M4 14a8 8 0 0 1 4-6.9"/><path d="M12 14l4-3"/><path d="M4 18h16"/></svg>`,
  distance: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18h18"/><path d="M5 18V8"/><path d="M19 18V8"/><path d="M5 12h14"/><path d="M16 9l3 3-3 3"/><path d="M8 9l-3 3 3 3"/></svg>`,
  direction: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M12 12l5-3"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/></svg>`,
};
---

<section class="section features" id="features">
  <div class="container">
    <header class="features__head">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 set:html={t.h2}></h2>
      <p class="lead">{t.lead}</p>
    </header>

    <div class="features__grid">
      {features.map((f) => (
        <article class="feat">
          <span class="feat__icon" aria-hidden="true" set:html={icons[f.icon]} />
          <h3 class="feat__title">{f.title}</h3>
          <p class="feat__body">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features__head { max-width: 38ch; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .features__head h2 { margin: 0.75rem 0 0.75rem; }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .feat {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2rem);
  }
  .feat__icon {
    display: inline-flex;
    width: 44px; height: 44px;
    align-items: center; justify-content: center;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .feat__icon :global(svg) { width: 24px; height: 24px; }
  .feat__title { font-size: 1.2rem; margin-bottom: 0.5rem; }
  .feat__body { color: var(--text-dim); font-size: 0.98rem; }

  @media (max-width: 620px) {
    .features__grid { grid-template-columns: 1fr; }
  }
</style>
