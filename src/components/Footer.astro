---
import { site } from "../config";
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).footer;
const year = new Date().getFullYear();
const socials = [
  { name: "YouTube", url: site.social.youtube },
  { name: "Instagram", url: site.social.instagram },
].filter((s) => s.url);
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <span class="footer__wordmark">TempoSeeker</span>
      <p class="footer__tagline">{t.tagline}</p>
      {socials.length > 0 && (
        <div class="footer__social">
          <span class="footer__colhead">{t.follow}</span>
          <div class="footer__social-links">
            {socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener">{s.name}</a>
            ))}
          </div>
        </div>
      )}
    </div>

    <nav class="footer__links" aria-label="Footer">
      <a href="#how">{t.navHow}</a>
      <a href="#features">{t.navFeatures}</a>
      <a href="#pricing">{t.navPricing}</a>
      <a href="#faq">{t.navFaq}</a>
    </nav>

    <nav class="footer__legal" aria-label="Legal">
      <a href="/privacy">{t.privacy}</a>
      <a href="/terms">{t.terms}</a>
      <a href={`mailto:${site.supportEmail}`}>{t.support}</a>
    </nav>
  </div>

  <div class="container footer__bottom">
    <span>© {year} TempoSeeker. {t.rights}</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding-block: clamp(2.5rem, 6vw, 4rem) 1.5rem;
    margin-top: var(--section-y);
  }
  .footer__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem 3rem;
    justify-content: space-between;
  }
  .footer__wordmark { font-weight: 700; font-size: 1.15rem; color: var(--accent); font-family: var(--font-serif); }
  .footer__tagline { color: var(--text-mute); font-size: 0.9rem; margin-top: 0.35rem; }

  .footer__links, .footer__legal { display: flex; flex-direction: column; gap: 0.6rem; }
  .footer__links a, .footer__legal a { color: var(--text-dim); font-size: 0.95rem; }
  .footer__links a:hover, .footer__legal a:hover { color: var(--text); }

  .footer__social { margin-top: 1.1rem; }
  .footer__colhead {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ink-faint);
  }
  .footer__social-links { display: flex; gap: 1rem; margin-top: 0.5rem; }
  .footer__social-links a { color: var(--text-dim); font-size: 0.95rem; }
  .footer__social-links a:hover { color: var(--accent); }

  .footer__bottom {
    margin-top: 2.5rem;
    color: var(--text-mute);
    font-size: 0.85rem;
  }
</style>
