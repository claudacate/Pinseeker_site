---
import AppStoreBadge from "./AppStoreBadge.astro";
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).hero;
---

<section class="hero">
  <div class="container hero__grid">
    <div class="hero__copy">
      <span class="eyebrow">{t.eyebrow}</span>
      <h1 set:html={t.h1}></h1>
      <p class="lead">{t.lead}</p>
      <div class="hero__cta">
        <AppStoreBadge lang={lang} />
      </div>
    </div>

    <div class="hero__media">
      <div class="hero__frame">
        <video
          class="hero__video"
          src="/media/hero.mp4"
          poster="/media/hero-poster.jpg"
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
        >
          <source src="/media/hero.webm" type="video/webm" />
          <source src="/media/hero.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding-block: clamp(3rem, 8vw, 6rem) var(--section-y); }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero__copy h1 { margin: 1rem 0 1.25rem; max-width: 14ch; }
  .hero__copy .lead { max-width: 46ch; }
  .hero__cta { margin-top: 2rem; }

  .hero__media { display: flex; justify-content: center; }

  .hero__frame {
    position: relative;
    width: 100%;
    max-width: 340px;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.55);
  }
  .hero__video { width: 100%; height: 100%; object-fit: cover; }

  @media (max-width: 820px) {
    .hero__grid { grid-template-columns: 1fr; text-align: center; }
    .hero__copy h1, .hero__copy .lead { max-width: none; margin-inline: auto; }
    .hero__cta { display: flex; justify-content: center; }
    .hero__media { order: -1; }
    .hero__frame { max-width: 280px; }
  }
</style>
