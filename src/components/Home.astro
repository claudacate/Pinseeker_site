---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Hero from "./Hero.astro";
import TrustBand from "./TrustBand.astro";
import PromoVideo from "./PromoVideo.astro";
import HowItWorks from "./HowItWorks.astro";
import Features from "./Features.astro";
import Demo from "./Demo.astro";
import Science from "./Science.astro";
import Coaching from "./Coaching.astro";
import Pricing from "./Pricing.astro";
import FAQ from "./FAQ.astro";
import Footer from "./Footer.astro";
import { defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
---

<Layout lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <TrustBand lang={lang} />
    <PromoVideo lang={lang} />
    <HowItWorks lang={lang} />
    <Features lang={lang} />
    <Demo lang={lang} />
    <Science lang={lang} />
    <Coaching lang={lang} />
    <Pricing lang={lang} />
    <FAQ lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
