---
import { Image } from "astro:assets";
import stepAim from "../assets/screens/step-aim.png";
import stepZone from "../assets/screens/step-zone.png";
import stepResult from "../assets/screens/step-result.png";
import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).how;
const imgs = [stepAim, stepZone, stepResult];
const steps = t.steps.map((s, i) => ({ ...s, img: imgs[i] }));
---

<section class="section how" id="how">
  <div class="container">
    <header class="how__head">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2 set:html={t.h2}></h2>
    </header>

    <ol class="how__steps">
      {steps.map((s) => (
        <li class="step">
          <div class="step__media">
            <Image src={s.img} alt={s.alt} widths={[400, 700, 900]} sizes="(max-width: 820px) 90vw, 32vw" />
          </div>
          <span class="step__n">{s.n}</span>
          <h3 class="step__title">{s.title}</h3>
          <p class="step__body">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how__head { max-width: 30ch; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .how__head h2 { margin-top: 0.75rem; }

  .how__steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .step__media {
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--line);
    margin-bottom: 1.25rem;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.4);
    aspect-ratio: 16 / 9;
  }
  .step__media :global(img) { width: 100%; height: 100%; object-fit: cover; }

  .step__n {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .step__title { font-size: 1.2rem; margin: 0.35rem 0 0.5rem; }
  .step__body { color: var(--text-dim); font-size: 0.98rem; }

  @media (max-width: 820px) {
    .how__steps { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
