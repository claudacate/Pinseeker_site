---
import { locales, localeNames, localePrefix, htmlLang, type Locale } from "../i18n";

interface Props { lang: Locale }
const { lang } = Astro.props;
---

<nav class="langswitch" aria-label="Language">
  {locales.map((l) => (
    <a
      href={localePrefix(l) || "/"}
      hreflang={htmlLang[l]}
      lang={htmlLang[l]}
      class={l === lang ? "on" : ""}
      aria-current={l === lang ? "true" : undefined}
    >{localeNames[l]}</a>
  ))}
</nav>

<style>
  .langswitch { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1.1rem; }
  .langswitch a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-faint);
    padding: 4px 10px;
    border-radius: 7px;
    border: 1px solid var(--line);
    transition: color 0.15s, border-color 0.15s;
  }
  .langswitch a:hover { color: var(--ink); border-color: var(--ink-faint); }
  .langswitch a.on { color: #0a0d0b; background: var(--accent); border-color: var(--accent); }
</style>
