---
/* "See it in action" — localized promo film as a YouTube facade.
 * Loads nothing from YouTube until the user clicks Play (then uses the
 * privacy-friendly youtube-nocookie domain). The whole section auto-hides
 * while the locale's ID and the English fallback are both empty. */
import { getContent, defaultLocale, type Locale } from "../i18n";
import { site } from "../config";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const t = getContent(lang).video;
const id = site.youtubeIds[lang] || site.youtubeIds.en || "";
const thumb = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : "";
---

{id && (
  <section class="section promo" id="film">
    <div class="container">
      <header class="promo__head">
        <span class="eyebrow">{t.eyebrow}</span>
        <h2 set:html={t.h2}></h2>
        <p class="lead">{t.lead}</p>
      </header>

      <div class="promo__frame">
        <button
          class="lite-yt"
          data-id={id}
          aria-label={t.playLabel}
          style={`background-image:url('${thumb}')`}
        >
          <span class="lite-yt__play" aria-hidden="true">
            <svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.5 7.4a8 8 0 0 0-5.6-5.7C56 .5 34 .5 34 .5s-22 0-26.9 1.2A8 8 0 0 0 1.5 7.4 83 83 0 0 0 .3 24a83 83 0 0 0 1.2 16.6 8 8 0 0 0 5.6 5.7C12 47.5 34 47.5 34 47.5s22 0 26.9-1.2a8 8 0 0 0 5.6-5.7A83 83 0 0 0 67.7 24a83 83 0 0 0-1.2-16.6z" fill="#f2b13c"/><path d="M27 34.5 45 24 27 13.5z" fill="#0c0f0e"/></svg>
          </span>
        </button>
      </div>
    </div>
  </section>
)}

<style>
  .promo__head { max-width: 34ch; margin-bottom: clamp(2rem, 5vw, 3rem); }
  .promo__head h2 { margin: 0.75rem 0 0.75rem; }

  .promo__frame {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin-inline: auto;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.55);
    background: #000;
  }
  .lite-yt {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    padding: 0;
    cursor: pointer;
    background-color: #000;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter 0.2s ease;
  }
  .lite-yt::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 60% at 50% 50%, transparent, rgba(0, 0, 0, 0.45));
  }
  .lite-yt:hover { filter: brightness(1.05); }
  .lite-yt__play { position: relative; z-index: 1; transition: transform 0.15s ease; }
  .lite-yt:hover .lite-yt__play { transform: scale(1.08); }
  .promo__frame :global(iframe) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>

<script>
  // Swap the facade for the real player only on click (no YouTube until then).
  document.querySelectorAll<HTMLButtonElement>(".lite-yt").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.id;
      if (!id) return;
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&playsinline=1&rel=0`;
      iframe.allow = "autoplay; encrypted-media; picture-in-picture";
      iframe.allowFullscreen = true;
      btn.replaceWith(iframe);
    });
  });
</script>
