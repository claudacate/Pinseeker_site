---
/* Slim trust strip under the hero. Privacy-led — the on-device story is both
   a reassurance and a selling point. Claims kept to what's true: camera frames
   analysed on-device and never uploaded; runs offline; no sign-up. */

import { getContent, defaultLocale, type Locale } from "../i18n";

interface Props { lang?: Locale }
const { lang = defaultLocale } = Astro.props;
const iconKeys = ["shield", "offline", "user"] as const;
const points = getContent(lang).trust.points.map((p, i) => ({ ...p, icon: iconKeys[i] }));

const icons: Record<string, string> = {
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>`,
  offline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="2.5" width="10" height="19" rx="2.5"/><line x1="11" y1="18.5" x2="13" y2="18.5"/></svg>`,
  user: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>`,
};
---

<section class="trust" aria-label="Privacy and setup">
  <div class="container trust__grid">
    {points.map((p) => (
      <div class="trust__item">
        <span class="trust__icon" aria-hidden="true" set:html={icons[p.icon]} />
        <div>
          <div class="trust__title">{p.title}</div>
          <p class="trust__body">{p.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    border-block: 1px solid var(--line);
    background: var(--panel);
    padding-block: clamp(1.5rem, 3vw, 2rem);
  }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }
  .trust__item { display: flex; gap: 0.85rem; align-items: flex-start; }
  .trust__icon {
    display: inline-flex; flex-shrink: 0;
    width: 38px; height: 38px;
    align-items: center; justify-content: center;
    border-radius: 10px;
    background: var(--accent-soft); color: var(--accent);
  }
  .trust__icon :global(svg) { width: 21px; height: 21px; }
  .trust__title { font-weight: 600; font-size: 0.98rem; margin-bottom: 0.2rem; }
  .trust__body { color: var(--ink-soft); font-size: 0.88rem; line-height: 1.45; }

  @media (max-width: 720px) {
    .trust__grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }
</style>
